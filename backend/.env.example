# =====================================================================
# U-BIKE BACKEND ENVIRONMENT
# Copy this file to ".env" and fill in values AFTER rotating all keys.
# The real ".env" is gitignored and must never be committed or pushed.
# =====================================================================

NODE_ENV=development
PORT=8080

# --- Supabase ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=rotate_and_paste_new_anon_key
SUPABASE_SERVICE_ROLE_KEY=rotate_and_paste_new_service_role_key

# --- Paystack (use TEST keys until launch; rotate the live key you exposed) ---
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_PUBLIC_KEY=pk_test_xxx
PAYSTACK_WEBHOOK_SECRET=set_in_paystack_dashboard

# --- Maps / Routing ---
GOOGLE_MAPS_API_KEY=restrict_by_referrer_and_paste
MAPBOX_ACCESS_TOKEN=rotate_and_paste
ORS_API_KEY=rotate_and_paste

# --- Realtime calls/chat ---
ZEGO_APP_ID=
ZEGO_SERVER_SECRET=rotate_and_paste

# --- Redis (queues / geo matching) ---
REDIS_URL=rediss://default:PASSWORD@host:6379

# --- Firebase Cloud Messaging (admin SDK) ---
# Path to the gitignored service-account JSON, OR paste the JSON as one line.
FIREBASE_SERVICE_ACCOUNT_PATH=./secrets/firebase-adminsdk.json

# --- Platform business rules ---
COMMISSION_RATE=0.20
FOUNDING_BIKE_SLOTS=10
FOUNDING_CAR_SLOTS=10
BIKE_REGISTRATION_FEE=2000
CAR_REGISTRATION_FEE=4000
MAX_RIDER_PRICE_ADJUSTMENT=0.30
UPFRONT_PAYMENT_RATIO=0.50
